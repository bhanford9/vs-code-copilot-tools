# Runtime / machine-local files — never commit these
*.zip
*.log

# Azure DevOps credential config — contains PAT, never commit
.azure-devops

# Per-user lessons learned — workspace/codebase-specific, never shared
# Each user's LessonsLearned.md grows independently per workspace.
# Globally-applicable process notes live in LessonsLearned.GLOBAL.md (tracked).
**/LessonsLearned.md

# Project-specific skills that live in this folder locally but are not shared
.github/skills/

# Machine-local workspace documentation configuration — unique per machine, never shared
workspace-docs.json

# VS Code Copilot runtime data
command-history-state.json
config.json

# Prompts to retire (replaced by git workflow)
prompts/consolidate-copilot-tools.prompt.md
prompts/pack-copilot-tools.prompt.md
prompts/unpack-copilot-tools.prompt.md

.github/**